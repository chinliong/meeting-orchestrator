ANTHROPIC_API_KEY=sk-ant-your-api-key-here
DATABASE_URL=sqlite:///./orchestrator.db
CLAUDE_MODEL=claude-sonnet-4-6
# Secret used to sign account auth tokens (JWT). Use a long random string in production;
# rotating it invalidates all existing logins.
AUTH_SECRET=dev-insecure-secret-change-me
# Comma-separated allowed frontend origins (CORS). Defaults to http://localhost:3000.
CORS_ORIGINS=http://localhost:3000
# --- Audio transcription (Objective 4) ---
# Preferred: hosted Whisper API (works on memory-limited hosts like Render free tier).
# OpenAI: set the key below, leave BASE_URL/MODEL unset (defaults to whisper-1).
# Groq:   set the key, BASE_URL=https://api.groq.com/openai/v1, MODEL=whisper-large-v3-turbo
#         (turbo is faster than whisper-large-v3 at near-identical accuracy).
TRANSCRIPTION_API_KEY=
# TRANSCRIPTION_BASE_URL=https://api.groq.com/openai/v1
# TRANSCRIPTION_MODEL=whisper-large-v3-turbo
#
# Fallback only: local Whisper model (needs `pip install -r requirements-audio.txt`).
# Used when TRANSCRIPTION_API_KEY is empty. Size: tiny|base|small|medium|large.
WHISPER_MODEL_SIZE=base
#
# --- Outbound email (password-reset codes) ---
# Two ways to send; if neither is set, codes are just logged (fine for local dev).
#
# 1) Brevo HTTPS API (REQUIRED on hosts that block SMTP, e.g. Render free tier).
#    Sign up at brevo.com (free 300/day) -> verify a sender address under Senders ->
#    SMTP & API -> API Keys -> create a key. Set BREVO_API_KEY and SMTP_FROM (the
#    verified sender). This sends over port 443, so it isn't blocked.
# BREVO_API_KEY=xkeysib-...
# SMTP_FROM=you@example.com
#
# 2) SMTP (local dev or hosts that allow outbound SMTP). Gmail example below; needs an
#    App Password (Google account -> Security -> App passwords; requires 2FA).
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=you@gmail.com
# SMTP_PASSWORD=your-app-password
# SMTP_FROM=you@gmail.com
